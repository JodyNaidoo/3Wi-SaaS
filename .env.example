# ============================================================
# 3Wi PMO Suite - Environment Variables (master example)
# Copy to .env at the repo root and fill in real values.
# ============================================================

# --- Quick-start: set MOCK_MODE=true to run with zero third-party keys ---
# When MOCK_MODE=true the API bypasses Anthropic, Stripe and Resend entirely
# and returns realistic stubbed responses. See NO_KEYS_DEPLOY.md for details.
MOCK_MODE=true

# (optional) per-service overrides - any of these set to true forces that one
# service into mock mode while the others stay live.
# MOCK_CLAUDE=false
# MOCK_STRIPE=false
# MOCK_RESEND=false

# (optional) speed up mock streaming output (ms between word chunks). 0 = instant.
# MOCK_STREAM_DELAY_MS=12

# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"

# --- Supabase ---
SUPABASE_URL="https://PROJECT.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_BUCKET="photos"

# --- Anthropic ---
# Bypassed when MOCK_MODE=true. If left blank with MOCK_MODE=false the API
# will still auto-fall-back to mock and emit a one-time console warning.
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# --- Stripe ---
# Bypassed when MOCK_MODE=true. In mock mode the webhook handler accepts any
# POST as valid and the checkout returns a local /billing/mock-checkout URL.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."

# --- Resend ---
# Bypassed when MOCK_MODE=true. Mock mode logs the email and appends it to
# apps/api/.mock-outbox.jsonl for local inspection.
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="3Wi PMO <noreply@3wipmo.co.za>"

# --- JWT ---
JWT_SECRET="change-me-256-bit-secret"
JWT_REFRESH_SECRET="change-me-different-256-bit-secret"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# --- Redis ---
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"

# --- API ---
API_PORT="4000"
API_BASE_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# --- Frontend (web) ---
VITE_API_URL="http://localhost:4000"
VITE_SUPABASE_URL="https://PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Marketing ---
VITE_DEMO_TENANT_SLUG="sunshines"
