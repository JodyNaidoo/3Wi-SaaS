# ===========================================
# 3Wi PMO SaaS — .gitignore
# ===========================================

# Secrets — NEVER commit any .env file
.env
.env.local
.env.*.local
*.env
!.env.example

# Password backups (the one we made in Documents — never commit)
supabase-*-password.txt
*password*.txt

# Node dependencies (regenerated by npm install)
node_modules/
.npm/

# Prisma generated client (regenerated by prisma generate)
.prisma/
**/node_modules/.prisma/

# Build outputs
dist/
build/
.next/
.turbo/
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS junk
.DS_Store
Thumbs.db
*.swp
*~

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# TypeScript build artefacts
*.tsbuildinfo

# Backup files we created during the migration fixes
*.bak
**/schema.prisma.bak-*
prisma/_backups/

# OneDrive lock files
~$*

# Local-only working folders
outputs/
scratch/

# Catch dated backups (e.g. server.ts.bak-20260529-114831)
*.bak.*
*.bak-*
*.backup
*.backup-*
