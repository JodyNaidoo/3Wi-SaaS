/* ====================================================================
   RENDERER — plain DOM, no string parsing
   ==================================================================== */
const el = (tag, props = {}, children = []) => {
  const e = document.createElement(tag);
  Object.entries(props).forEach(([k, v]) => {
    if (k === 'class') e.className = v;
    else if (k === 'html') e.innerHTML = v;
    else if (k.startsWith('on')) e.addEventListener(k.slice(2).toLowerCase(), v);
    else if (v === true) e.setAttribute(k, '');
    else if (v !== false && v !== null && v !== undefined) e.setAttribute(k, v);
  });
  (Array.isArray(children) ? children : [children]).forEach(c => {
    if (c == null) return;
    e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
  });
  return e;
};

function renderField(f) {
  const id = 'f-' + f.id;
  const inputProps = {
    id, name: f.id, type: f.type || 'text',
    placeholder: f.placeholder || '',
    class: 'w-full border border-slate-300 rounded-md px-3 py-1.5 text-sm' +
           (f.prefix ? ' pl-7' : '') + (f.suffix ? ' pr-10' : ''),
  };
  if (f.required) inputProps.required = true;
  if (f.min !== undefined) inputProps.min = f.min;
  if (f.max !== undefined) inputProps.max = f.max;
  if (f.step) inputProps.step = f.step;
  const input = el('input', inputProps);
  const wrap = el('div', { class: 'relative' }, [input]);
  if (f.prefix) wrap.appendChild(el('span', { class: 'absolute inset-y-0 left-2 flex items-center text-slate-400 text-xs pointer-events-none' }, [f.prefix]));
  if (f.suffix) wrap.appendChild(el('span', { class: 'absolute inset-y-0 right-2 flex items-center text-slate-400 text-xs pointer-events-none' }, [f.suffix]));
  return el('div', {}, [
    el('label', { for: id, class: 'block text-xs font-semibold text-slate-700 mb-1' }, [
      f.label, f.required ? el('span', { class: 'text-rose-600' }, [' *']) : null
    ]),
    wrap,
  ]);
}

function renderTextarea(f) {
  const id = 't-' + f.id;
  const ta = el('textarea', {
    id, name: f.id, rows: f.rows || 2,
    placeholder: f.placeholder || '',
    class: 'w-full border border-slate-300 rounded-md px-3 py-1.5 text-sm',
    ...(f.required ? { required: true } : {}),
  });
  return el('div', {}, [
    el('label', { for: id, class: 'block text-xs font-semibold text-slate-700 mb-1' }, [
      f.label, f.required ? el('span', { class: 'text-rose-600' }, [' *']) : null
    ]),
    ta,
  ]);
}

function renderCheckGroup(f, type) {
  const pills = (f.options || []).map(opt =>
    el('label', { class: 'check-pill' }, [
      el('input', { type, name: f.id, value: opt, ...(f.required && type === 'radio' ? { required: true } : {}) }),
      el('span', {}, [opt]),
    ])
  );
  return el('div', {}, [
    el('div', { class: 'text-xs font-semibold text-slate-700 mb-1' }, [
      f.label, f.required ? el('span', { class: 'text-rose-600' }, [' *']) : null
    ]),
    el('div', { class: 'flex flex-wrap gap-2' }, pills),
  ]);
}

function renderProductRow(f) {
  return el('div', { class: 'grid grid-cols-1 md:grid-cols-[1fr_120px_2fr] gap-2 items-center' }, [
    el('div', { class: 'text-sm text-slate-700' }, [f.label]),
    el('label', { class: 'check-pill' }, [
      el('input', { type: 'checkbox', name: f.id + '.interested', value: 'Yes' }),
