function renderDocGroup(f) {
  const slug = (f.title || '').replace(/[^a-zA-Z0-9]+/g, '_').toLowerCase();
  return el('div', {}, [
    el('h3', { class: 'text-sm font-bold text-slate-700 mb-2' }, [f.title]),
    el('div', { class: 'space-y-1 ml-1' }, (f.items || []).map((it, i) =>
      el('label', { class: 'flex items-start gap-2 cursor-pointer text-sm text-slate-700' }, [
        el('input', { type: 'checkbox', name: `doc.${slug}.${i}`, value: 'attached', class: 'mt-0.5' }),
        el('span', {}, [it]),
      ])
    )),
  ]);
}

function renderRefBlock(f) {
  return el('div', { class: 'border border-slate-200 rounded-lg p-4' }, [
    el('div', { class: 'font-semibold text-sm text-slate-700 mb-2' }, [f.title]),
    el('div', { class: 'grid grid-cols-1 md:grid-cols-2 gap-3' }, [
      renderField({ kind: 'field', id: f.idNameKey, label: 'Name + contact' }),
      renderField({ kind: 'field', id: f.idRelKey, label: 'Relationship to you' }),
    ]),
  ]);
}

function renderItem(f) {
  // Row wrapper
  if (f.row) {
    const cols = f.row.length;
    const gridClass = cols === 2 ? 'md:grid-cols-2' : cols === 3 ? 'md:grid-cols-3' : 'md:grid-cols-4';
    return el('div', { class: `grid grid-cols-1 ${gridClass} gap-3` }, f.row.map(renderItem));
  }
  switch (f.kind) {
    case 'field':       return renderField(f);
    case 'textarea':    return renderTextarea(f);
    case 'radio':       return renderCheckGroup(f, 'radio');
    case 'checkbox':    return renderCheckGroup(f, 'checkbox');
    case 'productRow':  return renderProductRow(f);
    case 'supportRow':  return renderSupportRow(f);
    case 'declare':     return renderDeclare(f);
    case 'docGroup':    return renderDocGroup(f);
    case 'refBlock':    return renderRefBlock(f);
    case 'subheader':   return el('div', {}, [
                          el('h3', { class: 'text-sm font-bold text-slate-700 mb-1 mt-2' }, [f.text]),
                          f.intro ? el('p', { class: 'text-xs text-slate-500 italic mb-2' }, [f.intro]) : null,
                        ]);
    case 'divider':     return el('hr', { class: 'border-slate-100 my-2' });
    case 'paragraph':   return el('p', { class: 'text-sm text-slate-700 ' + (f.bold ? 'font-semibold' : '') }, [f.text]);
    case 'note':        return el('p', { class: 'text-xs text-slate-500 italic' }, [f.text]);
    default:            return el('div', { class: 'text-xs text-rose-500' }, [`Unknown kind: ${f.kind}`]);
  }
}

function renderSection(s) {
  const headerChildren = [el('h2', { class: 'text-base font-bold text-slate-900' }, [s.title])];
  if (s.metaPill) {
    headerChildren.push(el('span', {
      class: 'text-xs font-semibold',
      style: `color: ${s.metaPill.color}`,
    }, [s.metaPill.text]));
  } else if (s.meta) {
    headerChildren.push(el('span', { class: 'text-xs text-slate-500 font-mono' }, [s.meta]));
  }

  const body = el('div', { class: 'p-5 space-y-4' });
  if (s.intro) body.appendChild(el('p', { class: 'text-xs text-slate-500 italic' }, [s.intro]));
  s.fields.forEach(f => body.appendChild(renderItem(f)));

  return el('section', { id: s.id, class: 'bg-white border border-slate-200 rounded-xl shadow-sm' }, [
    el('header', { class: 'px-5 py-3 border-b border-slate-100 flex items-center justify-between' }, headerChildren),
    body,
  ]);
}

