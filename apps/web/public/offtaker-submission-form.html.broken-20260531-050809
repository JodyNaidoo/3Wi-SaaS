/* ====================================================================
   AUTOSAVE / RESTORE / DOWNLOAD / API
   ==================================================================== */
const STORAGE_KEY = 'ecrda_offtaker_checklist_v1';

function snapshot() {
  const data = {};
  form.querySelectorAll('input, textarea, select').forEach(el => {
    if (!el.name) return;
    if (el.type === 'checkbox' || el.type === 'radio') {
      if (el.checked) {
        if (el.type === 'checkbox') {
          if (!data[el.name]) data[el.name] = [];
          data[el.name].push(el.value);
        } else {
          data[el.name] = el.value;
        }
      }
    } else if (el.value) {
      data[el.name] = el.value;
    }
  });
  return data;
}

function saveDraft() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ savedAt: new Date().toISOString(), data: snapshot() }));
    setAutosave('Draft saved · ' + new Date().toLocaleTimeString());
  } catch (e) { setAutosave('Draft save failed: ' + e.message); }
}

function restoreDraft() {
  const raw = localStorage.getItem(STORAGE_KEY);
  if (!raw) { alert('No saved draft on this device.'); return; }
  try {
    const { data } = JSON.parse(raw);
    Object.entries(data).forEach(([name, val]) => {
      const els = form.querySelectorAll(`[name="${CSS.escape(name)}"]`);
      els.forEach(el => {
        if (el.type === 'checkbox' || el.type === 'radio') {
          const values = Array.isArray(val) ? val : [val];
          el.checked = values.includes(el.value);
        } else {
          el.value = val;
        }
      });
    });
    updateProgress();
    setAutosave('Draft restored');
  } catch (e) { alert('Could not restore: ' + e.message); }
}

function clearDraft() {
  if (!confirm('Clear the saved draft on this device?')) return;
  localStorage.removeItem(STORAGE_KEY);
  setAutosave('Draft cleared');
}

function setAutosave(msg) { document.getElementById('autosaveStatus').textContent = msg; }

let autosaveTimer;
form.addEventListener('input', () => {
  clearTimeout(autosaveTimer);
  autosaveTimer = setTimeout(saveDraft, 2500);
  updateProgress();
});

function updateProgress() {
  const els = form.querySelectorAll('input, textarea, select');
  const groups = new Set();
  const filled = new Set();
  els.forEach(el => {
    if (!el.name) return;
    groups.add(el.name);
    if (el.type === 'checkbox' || el.type === 'radio') {
      if (el.checked) filled.add(el.name);
    } else if ((el.value || '').trim()) {
      filled.add(el.name);
    }
  });
  const pct = groups.size ? Math.round((filled.size / groups.size) * 100) : 0;
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = pct + '%';
}

