{
  "name": "3wi-pmo-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"yellow.bold,cyan.bold\" --kill-others-on-fail \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "prisma:generate": "npm --prefix apps/api run prisma:generate",
    "prisma:migrate": "npm --prefix apps/api run prisma:migrate",
    "stop": "powershell -Command \"Get-Process node, tsx -ErrorAction SilentlyContinue | Stop-Process -Force\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "prisma": "5.22.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
